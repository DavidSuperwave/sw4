---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PageHero from "../components/PageHero.astro";
import ProductConsole from "../components/ProductConsole.astro";
import MetricStrip from "../components/MetricStrip.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import {
  auditChecks,
  auditOutcomes,
  faqs,
  integrations,
  mechanism,
  pageMeta,
  platformModules,
  pricingPlans,
  siteUrl,
  tools,
  useCases
} from "../data/site";

const { title, description } = pageMeta.home;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Superwave",
    url: siteUrl,
    description
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Superwave",
    url: siteUrl,
    description
  }
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main>
    <PageHero
      eyebrow="Meet Superwave"
      title="Managed outbound infrastructure for teams that need cold email to work."
      copy="Superwave provisions the sending rails, monitors deliverability, routes replies, stores lead signal, and feeds the CloseOS intelligence layer so outbound behaves like a real sales channel."
      primary="Run free audit"
      secondary="Explore platform"
    >
      <ProductConsole />
    </PageHero>

    <MetricStrip />

    <section class="audit-section">
      <div class="section-inner audit-grid">
        <div>
          <p class="eyebrow">Free audit</p>
          <h2>Know whether the offer failed or the rails failed.</h2>
        </div>
        <div class="audit-checks" aria-label="What the Superwave audit checks">
          {auditChecks.map((item) => (
            <article><strong>{item.title}</strong><span>{item.copy}</span></article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner">
        <SectionHeader
          eyebrow="Audit output"
          title="A useful answer, not another vague discovery call."
          copy="The audit should leave operators with a concrete view of what is working, what is risky, and which Superwave path fits the current outbound motion."
          align="center"
        />
        <div class="feature-grid three-up">
          {auditOutcomes.map((item) => (
            <article class="feature-card">
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner split-grid">
        <SectionHeader
          eyebrow="The category problem"
          title="Most campaigns break before the first reply."
          copy="Sequencers show sends. They do not tell you whether the infrastructure is healthy, whether the primary domain is protected, or whether reply data is becoming operational intelligence."
        />
        <div class="diagnostic-panel">
          <div class="diagnostic-row"><span>Warmup score</span><strong>Green</strong><em>Inbox path still unstable</em></div>
          <div class="diagnostic-row"><span>Microsoft path</span><strong>At risk</strong><em>Silent throttling detected</em></div>
          <div class="diagnostic-row"><span>Reply routing</span><strong>Fragmented</strong><em>13 inboxes need triage</em></div>
          <div class="diagnostic-row"><span>Primary domain</span><strong>Protected</strong><em>Outbound isolated</em></div>
        </div>
      </div>
    </section>

    <section class="content-section surface-section">
      <div class="section-inner">
        <SectionHeader
          eyebrow="Operating mechanism"
          title="The stack starts underneath the sequencer."
          copy="Superwave turns outbound infrastructure into a managed operating layer instead of a collection of inboxes, checklists, and hunches."
          align="center"
        />
        <div class="timeline-grid">
          {mechanism.map((step, index) => (
            <article class="timeline-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner">
        <SectionHeader
          eyebrow="Platform"
          title="One operator layer across infrastructure, replies, and signal."
          copy="These are the product surfaces that turn delivery into a system operators can inspect, improve, and scale."
        />
        <div class="feature-grid three-up">
          {platformModules.map((module) => (
            <a class="feature-card card-link" href="/platform">
              <h3>{module.title}</h3>
              <p>{module.copy}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section surface-section">
      <div class="section-inner split-grid">
        <div>
          <SectionHeader
            eyebrow="Use cases"
            title="Built for serious outbound operators."
            copy="The same infrastructure layer supports agencies, SDR teams, founder-led sales, recruiting, and RevOps without changing the core promise."
          />
        </div>
        <div class="compact-list">
          {useCases.map((item) => (
            <a class="list-link" href={item.href}>
              <strong>{item.title}</strong>
              <span>{item.copy}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner split-grid">
        <SectionHeader
          eyebrow="Free tools"
          title="Useful diagnostics before the call."
          copy="The tools pages create SEO surface area and give operators a reason to trust Superwave before they buy managed infrastructure."
        />
        <div class="tag-grid">
          {tools.map((tool) => <a href="/tools">{tool}</a>)}
        </div>
      </div>
    </section>

    <section class="content-section surface-section">
      <div class="section-inner product-story-grid">
        <ProductConsole mode="compact" />
        <div>
          <SectionHeader
            eyebrow="CloseOS"
            title="The premium layer starts once signal starts flowing."
            copy="Superwave creates the activity data. CloseOS turns replies, bounces, objections, and segment performance into decisions for the next campaign, script, and market."
          />
          <div class="signal-cards">
            <a href="/closeos">ICP signal map</a>
            <a href="/closeos">Objection intelligence</a>
            <a href="/closeos">Script generator</a>
            <a href="/closeos">Campaign recommendations</a>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner">
        <SectionHeader
          eyebrow="Integrations"
          title="Keep the sequencer. Upgrade the rails."
          copy="Superwave is designed to work with the outbound tools teams already operate."
          align="center"
        />
        <div class="logo-grid">
          {integrations.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="content-section surface-section">
      <div class="section-inner">
        <SectionHeader
          eyebrow="Pricing"
          title="Simple entry point. Managed scale when you need it."
          align="center"
        />
        <div class="pricing-grid">
          {pricingPlans.map((plan) => (
            <a class="price-card card-link" href="/pricing">
              <h3>{plan.name}</h3>
              <strong>{plan.price}</strong>
              <p>{plan.copy}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-inner split-grid">
        <SectionHeader eyebrow="FAQ" title="The questions serious operators ask first." />
        <div class="faq-list">
          {faqs.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CtaBand />
  </main>
  <SiteFooter />
</BaseLayout>
