---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
  align?: "left" | "center";
}

const { eyebrow, title, copy, align = "left" } = Astro.props;
---

<div class:list={["section-header", align === "center" && "section-header-center"]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {copy && <p>{copy}</p>}
</div>
