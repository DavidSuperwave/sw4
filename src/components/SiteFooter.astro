---
import { navItems } from "../data/site";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <a class="brand footer-brand" href="/" aria-label="Superwave home">
        <img src="/assets/superwave-logo-white.png" alt="Superwave" width="112" height="30" />
      </a>
      <p>Managed outbound infrastructure for teams that need cold email to behave like a reliable sales channel.</p>
    </div>
    <div class="footer-links">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/blog">Blog</a>
    </div>
  </div>
</footer>
