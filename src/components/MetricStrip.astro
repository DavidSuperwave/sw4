---
import { proofMetrics } from "../data/site";
---

<section class="metric-strip" aria-label="Superwave proof points">
  <div class="section-inner metric-grid">
    {proofMetrics.map((metric) => (
      <div class="metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    ))}
  </div>
</section>
